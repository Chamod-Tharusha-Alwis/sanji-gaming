# Environment Variables
# Copy this file to .env and fill in your values

# MongoDB
MONGO_URI=mongodb://localhost:27017/sanji-gaming

# JWT
JWT_SECRET=sanji-gaming-jwt-secret-change-this-in-production

# Cloudinary (Get from https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin Account (Default: admin / admin123)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# WhatsApp (Sri Lankan format, without +)
ADMIN_WHATSAPP_NUMBER=94XXXXXXXXX

# Server
PORT=5000
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
